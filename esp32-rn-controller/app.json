{
  "expo": {
    "name": "ESP32 Controller",
    "slug": "esp32-controller",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1976D2"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1976D2"
      },
      "package": "com.esp32controller",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.esp32controller",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Used to connect to ESP32 via BLE",
        "NSLocationWhenInUseUsageDescription": "Required for BLE scanning"
      }
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "Allow ESP32 Controller to use Bluetooth"
        }
      ]
    ]
  }
}
